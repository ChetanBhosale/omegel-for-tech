# ┌──────────────────────────────────────────────────────────────┐
# │  ENV REFERENCE                                                 │
# │  Copy to `.env` for local dev. For production, set these in    │
# │  your host's dashboard (Railway = backend, Vercel = frontend). │
# │                                                                │
# │  Domains:                                                      │
# │    Frontend : https://omeglefortech.com                        │
# │    Backend  : https://app.omeglefortech.com                    │
# └──────────────────────────────────────────────────────────────┘

# ============================ BACKEND ============================
# Set these on the backend host (Railway).

# Server. NODE_ENV must be "production" in prod so cookies use
# Secure + SameSite=None (required for cross-domain auth).
NODE_ENV=production
# PORT is injected by the host (Railway/Render). Leave unset there.
PORT=4000
HTTP_PORT=4000

# Frontend origin — used for CORS and the post-login redirect target.
# Local:      http://localhost:3000
# Production: https://omeglefortech.com
FRONTEND_URL=https://omeglefortech.com

# Database (Neon Postgres). Prefer the POOLED connection string in prod.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Redis (Upstash) — matching queue + presence.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Auth. Use a long random string in prod (e.g. `openssl rand -hex 32`).
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=7d

# GitHub OAuth. The callback URL points at the BACKEND and must EXACTLY
# match the "Authorization callback URL" in your GitHub OAuth app.
# Local:      http://localhost:4000/api/auth/github/callback
# Production: https://app.omeglefortech.com/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=https://app.omeglefortech.com/api/auth/github/callback

# =========================== FRONTEND ============================
# Set these on the frontend host (Vercel). NEXT_PUBLIC_* are inlined
# at BUILD time — redeploy after changing them.
# IMPORTANT: no trailing slash, no spaces, just the bare origin.

# Backend base URL.
# Local:      http://localhost:4000
# Production: https://app.omeglefortech.com
NEXT_PUBLIC_BACKEND_URL=https://app.omeglefortech.com

# Backend WebSocket URL (same host; http(s) is auto-converted to ws(s)).
# Local:      http://localhost:4000
# Production: https://app.omeglefortech.com
NEXT_PUBLIC_BACKEND_WS_URL=https://app.omeglefortech.com
